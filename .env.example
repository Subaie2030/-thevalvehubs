# ─── TheValveHubs — Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values
# In Netlify: Site Settings → Environment Variables

# ─── DATABASE (Neon PostgreSQL) ───────────────────────────────────────
# Get from: https://neon.tech → New Project → Connection String
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── JWT ──────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_key_here_minimum_64_chars_long_random_string

# JWT token expiry (e.g. 7d, 24h, 30d)
JWT_EXPIRES_IN=7d

# ─── EMAIL (optional — for notifications) ────────────────────────────
# Use Gmail App Password (not your regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=TheValveHubs <noreply@thevalvehubs.com>

# ─── WHATSAPP (optional — Twilio or WhatsApp Business API) ───────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── SITE URL ─────────────────────────────────────────────────────────
SITE_URL=https://thevalvehubs.netlify.app

# ─── NODE ENV ─────────────────────────────────────────────────────────
NODE_ENV=production
